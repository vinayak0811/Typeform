APP_NAME=Typeform Clone API
ENV=development
DEBUG=true

# SQLite by default; swap for a Postgres URL in production if desired.
DATABASE_URL=sqlite:///./typeform_clone.db

FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000/f

# --- Auth ---
# Generate a real value with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=30
COOKIE_SECURE=false
