# Copy this to backend/.env and frontend/.env.local respectively,
# or use these values directly with docker-compose.

# --- Backend ---
DATABASE_URL=sqlite:///./typeform_clone.db
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000/f
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=30
COOKIE_SECURE=false

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
